# ── Required ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── AWS (defaults work if running on EC2 with an IAM role) ──
# AWS_REGION=us-east-2
# SQS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/585192672941/decoy-events-aggregated
# REPORT_BUCKET=decoy-ai-agent-report

# ── LLM models ──────────────────────────────────────────────
# LIGHTWEIGHT_MODEL=gpt-4o-mini
# ADVANCED_MODEL=gpt-5.4

# ── SQS polling ─────────────────────────────────────────────
# SQS_WAIT_TIME_SECONDS=10
# SQS_VISIBILITY_TIMEOUT=120
# POLL_INTERVAL_SECONDS=30

# ── Agent behaviour ─────────────────────────────────────────
# LANGGRAPH_RECURSION_LIMIT=25
# MAX_RETRIES=3
# RETRY_BACKOFF_BASE=2.0

# ── Observability ───────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json          # "json" for production, "text" for development
# HEALTH_FILE=/tmp/agent_healthy
